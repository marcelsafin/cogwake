# cogwake configuration — copy to /usr/local/etc/cogwake.env and edit.
# All values optional; shown here are the defaults. (install.sh copies this for you.)

# Processes that count as "an AI agent" (case-insensitive, matched against the
# full command line). Add your tools here. VS Code Copilot is covered by
# "copilot" (its copilot-language-server). To cover the VS Code extension host
# broadly, add: |Code Helper \(Plugin\)  — but that also catches other busy
# extensions, so only do it if you accept the false holds.
# AGENT_RE='copilot|claude|codex|aider|cursor-agent|ollama|gemini-cli|continue'

# CPU-sampling window in seconds.
# WINDOW=2

# CPU-seconds the agent tree must burn within WINDOW to count as "working".
# 0.30 / 2 ≈ 15% of one core. Lower = more sensitive (more likely to stay awake).
# BUSY_CPU=0.30

# Stay awake this long after the last detected activity, then allow sleep.
# With the lid shut, this is roughly how long after the agent finishes the Mac
# sleeps. Covers quiet "thinking" gaps between token bursts and tool runs.
# HOLD=30

# Pause between checks while the lid is shut.
# POLL=5

# Pause between checks while the lid is open. Larger = less CPU. With the lid
# open cogwake only pre-arms (sets the flag so closing the lid mid-task is safe)
# and never runs the thermal sampler, so a slow poll here is cheap and fine.
# LID_OPEN_POLL=15

# On battery, release below this charge % so a closed laptop can't run flat.
# Default 0 = OFF: keep working until the battery dies. The thermal valve below
# guards the hardware instead. Set e.g. 15 to also protect the charge.
# BATT_FLOOR=0

# Thermal valve. 1 = when the lid is shut and macOS reports serious thermal
# pressure, release the override so the Mac sleeps and cools (a sealed bag has
# no airflow). 0 = never sleep for heat. Sampled only while the lid is shut.
# THERM_GUARD=1

# Pressure levels (from `powermetrics --samplers thermal`) that count as "too
# hot". macOS escalates roughly nominal -> moderate/fair -> heavy/serious ->
# trapping/critical -> sleeping. Default leaves normal-under-load (moderate/
# fair) alone and only sleeps on the serious end. Widen if your Mac cooks before
# it reaches these. Check /var/log/cogwake.log for the level it actually reports.
# THERM_RE='heavy|trapping|sleeping|serious|critical'

# Where the activity log goes.
# COGWAKE_LOG=/var/log/cogwake.log
